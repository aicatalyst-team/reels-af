OPENROUTER_API_KEY=sk-or-...
# Optional — falls back to OPENROUTER if not set
OPENAI_API_KEY=
# Default LLM call timeout in seconds (used by SDK)
AGENTFIELD_LLM_CALL_TIMEOUT=120
# Models (override as needed)
REEL_AF_NAVIGATOR_MODEL=openrouter/deepseek/deepseek-v4-pro
REEL_AF_ANGLE_MODEL=openrouter/deepseek/deepseek-v4-pro
REEL_AF_IMAGE_MODEL=openrouter/x-ai/grok-imagine-image-quality
REEL_AF_TTS_MODEL=openrouter/openai/gpt-audio-mini
REEL_AF_TTS_VOICE=nova
