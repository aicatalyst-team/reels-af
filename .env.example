# --- Provider key (OpenRouter — one key, every model) ---
# Get one at https://openrouter.ai/ and load $5+ in credits.
# Default config (ken-burns motion) costs ~$0.10 per reel — $5 buys ~50.
# Full Veo i2v motion bumps it to ~$1.20 per reel — see REEL_AF_USE_VEO.
OPENROUTER_API_KEY=sk-or-v1-...

# --- Motion source ---
# Default: ken-burns from generated stills (cheap, no Veo cost).
# Set to true to use Veo 3.1 Lite i2v for full motion (~$1.10 extra per reel).
REEL_AF_USE_VEO=false

# --- Reasoning model (every .ai() call) ---
REEL_AF_MODEL=openrouter/deepseek/deepseek-v4-pro
# Alternatives:
# REEL_AF_MODEL=openrouter/anthropic/claude-sonnet-4
# REEL_AF_MODEL=openrouter/openai/gpt-5
# REEL_AF_MODEL=openrouter/qwen/qwen3-235b-a22b-instruct
# REEL_AF_MODEL=openrouter/google/gemini-2.5-pro

# --- Advanced: bring your own reasoning endpoint (optional) ---
# Leave both unset to use OpenRouter (the default). To run reasoning against
# any OpenAI-compatible endpoint — a local vLLM/Ollama server, a self-hosted
# gateway, or another aggregator — set the model to that server's id and point
# these at it. Media (TTS/image/video) still uses OpenRouter, so keep
# OPENROUTER_API_KEY set.
#   REEL_AF_MODEL=openai/your-local-model
#   REEL_AF_API_BASE=http://localhost:8000/v1
#   REEL_AF_API_KEY=sk-local-or-anything
# REEL_AF_API_BASE=
# REEL_AF_API_KEY=

# --- Media models ---
# TTS: Gemini Flash supports 200+ inline tone tags.
REEL_AF_TTS_MODEL=google/gemini-3.1-flash-tts-preview

# Image: any text-to-image model that returns a 9:16-croppable still.
REEL_AF_IMAGE_MODEL=openrouter/google/gemini-2.5-flash-image
# REEL_AF_IMAGE_MODEL=openrouter/black-forest-labs/flux-1.1-pro

# Video: only used when REEL_AF_USE_VEO=true.
REEL_AF_VIDEO_MODEL=openrouter/google/veo-3.1-lite
# REEL_AF_VIDEO_MODEL=openrouter/google/veo-3.1

# --- AgentField control plane ---
AGENT_NODE_ID=reel-af
AGENTFIELD_SERVER=http://localhost:8080

# --- SDK behaviour ---
AGENTFIELD_LLM_CALL_TIMEOUT=120
